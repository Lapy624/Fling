-- ===== SAFE GET LOCAL CHARACTER =====
local function getLocalRoot()
    local char = LocalPlayer.Character
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart")
end

-- ===== UPDATE PLAYER LIST =====
local function updatePlayerList()
    for _, child in ipairs(playerList:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    playerButtons = {}

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            local b = Instance.new("TextButton")
            b.Size = UDim2.new(1, -4, 0, 28)
            b.Text = plr.Name
            b.BackgroundColor3 = Color3.fromRGB(40, 40, 60)
            b.BorderSizePixel = 0
            b.TextColor3 = Color3.fromRGB(200, 200, 220)
            b.Font = Enum.Font.Gotham
            b.TextSize = 14
            b.TextXAlignment = Enum.TextXAlignment.Left
            b.Parent = playerList
            local corner = Instance.new("UICorner")
            corner.CornerRadius = UDim.new(0, 4)
            corner.Parent = b

            if selectedPlayers[plr] then
                b.BackgroundColor3 = Color3.fromRGB(0, 100, 200)
            end

            b.MouseButton1Click:Connect(function()
                if selectedPlayers[plr] then
                    selectedPlayers[plr] = nil
                    b.BackgroundColor3 = Color3.fromRGB(40, 40, 60)
                else
                    selectedPlayers[plr] = true
                    b.BackgroundColor3 = Color3.fromRGB(0, 100, 200)
                end
                updateStatus()
            end)

            playerButtons[plr] = b
        end
    end

    local count = #playerList:GetChildren() - 1
    playerList.CanvasSize = UDim2.new(0, 0, 0, count * 32 + 10)
end

-- ===== MODE HIGHLIGHT =====
