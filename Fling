-- ===== РУКОПОЖАТИЕ (ЗАЩИТА ОТ УДАЛЕНИЯ СКРИПТА) =====
-- ============================================================
Players.PlayerAdded:Connect(function(player)
    -- Создаём GUI для игрока
    createGUI(player)

    -- Запускаем рукопожатие
    spawn(function()
        while player and player.Parent do
            task.wait(10) -- Проверка каждые 10 секунд

            local nonce = math.random(100000, 999999)
            player:SetAttribute("Handshake", nonce)
            remote:FireClient(player, "Ping", nonce)

            task.wait(3)
            if player:GetAttribute("Handshake") == nonce then
                -- Ответ получен
            else
                -- Нет ответа -> скрипт удалён
                KickPlayer(player, "AntiCheat")
            end
        end
    end)
end)

-- ===== ОБРАБОТКА ОТВЕТА НА РУКОПОЖАТИЕ =====
remote.OnServerEvent:Connect(function(player, mode, data)
    if mode == "Pong" then
        if typeof(data) ~= "number" then
            KickPlayer(player, "InvalidData")
            return
        end
        if player:GetAttribute("Handshake") == data then
            player:SetAttribute("Handshake", nil)
        end
    end
end)

