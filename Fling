-- Anti-AFK (имитация движения камеры)
local antiAFKConn = nil
local function toggleAntiAFK()
    CONFIG.AntiAFK = not CONFIG.AntiAFK
    if CONFIG.AntiAFK then
        antiAFKConn = RunService.RenderStepped:Connect(function()
            local cam = workspace.CurrentCamera
            if cam then
                local pos = cam.CFrame.Position
                cam.CFrame = CFrame.new(pos + Vector3.new(math.sin(tick())*0.001, 0, math.cos(tick())*0.001))
            end
        end)
    else
        if antiAFKConn then antiAFKConn:Disconnect() end
    end
end

-- Анти-кик (периодическая отправка пакетов)
local antiKickConn = nil
local function toggleAntiKick()
    if antiKickConn then
        antiKickConn:Disconnect()
        antiKickConn = nil
        return
    end
    antiKickConn = RunService.Heartbeat:Connect(function()
        pcall(function()
            -- Имитация активности
            local char = LocalPlayer.Character
            if char then
                local humanoid = char:FindFirstChild("Humanoid")
                if humanoid then
                    humanoid:Move(Vector3.new(0,0,0), true)
                end
            end
        end)
    end)
end

