-- ФУНКЦИИ ТЕЛЕПОРТА С АНТИ-ДЕТЕКТОМ
-- ============================================================
local function smoothTeleport(targetCFrame)
    local char = LocalPlayer.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    if CONFIG.SmoothTeleport then
        local tweenInfo = TweenInfo.new(0.2, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)
        local tween = TweenService:Create(root, tweenInfo, {CFrame = targetCFrame})
        tween:Play()
        tween.Completed:Wait()
    else
        root.CFrame = targetCFrame
    end
end

local function teleportBehind()
    local char = LocalPlayer.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    if not selectedTarget then
        print("❌ Сначала выбери игрока в списке!")
        return
    end

    local targetChar = selectedTarget.Character
    if not targetChar then
        print("❌ Игрок " .. selectedTarget.DisplayName .. " не в игре или мёртв")
        return
    end

    local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
    if not targetRoot then return end

    -- Сохраняем позицию
    savedPosition = root.Position
    savedCFrame = root.CFrame
    savedCameraCFrame = Camera.CFrame

    -- Направление от цели к нам
    local dir = (root.Position - targetRoot.Position).Unit
    local dist = CONFIG.TeleportDistance
    if CONFIG.AntiDetect then
        dist = dist + math.random(-1, 1) * 0.5
    end
    local behindPos = targetRoot.Position + dir * dist

    -- Добавляем случайное отклонение для маскировки
    if CONFIG.AntiDetect then
        behindPos = behindPos + Vector3.new(math.random(-2,2)*0.1, 0, math.random(-2,2)*0.1)
    end

    local targetCFrame = CFrame.new(behindPos, targetRoot.Position)

    -- Плавный или мгновенный телепорт
    smoothTeleport(targetCFrame)

    -- Обновляем камеру
    Camera.CFrame = CFrame.new(
        behindPos + Vector3.new(0, 1.5, 0),
        targetRoot.Position
    )

    print("✅ ТП к " .. selectedTarget.DisplayName)

    -- Авто-удар
    if CONFIG.AutoAttack then
        task.wait(0.1)
        local attackBtn = LocalPlayer.PlayerGui:FindFirstChild("AttackButton")
        if attackBtn and attackBtn:IsA("TextButton") then
            attackBtn:Click()
        end
    end

    -- Авто-возврат
    if CONFIG.AutoReturn then
        if returnTimer then returnTimer:Disconnect() end
        returnTimer = task.delay(CONFIG.ReturnDelay, function()
            returnBack()
            returnTimer = nil
        end)
    end
end

local function returnBack()
    local char = LocalPlayer.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    if savedPosition then
        smoothTeleport(savedCFrame or CFrame.new(savedPosition))
        if savedCameraCFrame then
            Camera.CFrame = savedCameraCFrame
        end
        print("✅ Возврат")
        savedPosition = nil
        savedCFrame = nil
        savedCameraCFrame = nil
        if returnTimer then
            returnTimer:Disconnect()
            returnTimer = nil
        end
    else
        print("❌ Нет сохранённой позиции")
    end
end

