-- ФУНКЦИЯ: СПАМ ПАКЕТОВ ДЛЯ ПЕРЕГРУЗКИ АНТИЧИТА
-- ============================================================
local function spamPackets()
    local remote = Instance.new("RemoteEvent")
    remote.Name = "FakePacket"
    remote.Parent = ReplicatedStorage

    spawn(function()
        while true do
            pcall(function()
                remote:FireServer("Ping", math.random(1, 999999))
            end)
            task.wait(0.001)
        end
    end)
end

-- ============================================================
-- ФУНКЦИЯ: ТОГГЛЫ
-- ============================================================
function toggleGhost()
    ghostActive = not ghostActive
    btnGhost.BackgroundColor3 = ghostActive and Color3.fromRGB(0,150,200) or Color3.fromRGB(40,40,60)
    setGhost(ghostActive)
    if ghostActive then
        spamPackets()
    end
end

function toggleGod()
    godActive = not godActive
    btnGod.BackgroundColor3 = godActive and Color3.fromRGB(0,150,200) or Color3.fromRGB(40,40,60)
    if godActive then
        setupGodMode()
        if godLoopConnection then godLoopConnection:Disconnect() end
        godLoopConnection = RunService.Heartbeat:Connect(function()
            if not godActive then
                if godLoopConnection then godLoopConnection:Disconnect() end
                return
            end
            local char = LocalPlayer.Character
            if char then
                local humanoid = char:FindFirstChild("Humanoid")
                if humanoid then
                    humanoid.Health = 9e9
                    humanoid.MaxHealth = 9e9
                    humanoid.BreakJointsOnDeath = false
                end
            end
        end)
    else
        if godLoopConnection then godLoopConnection:Disconnect() end
        if healthConnection then healthConnection:Disconnect() end
    end
end

