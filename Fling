-- ОБНОВЛЕНИЕ СПИСКА ИГРОКОВ
local function updatePlayerList()
    for _, child in ipairs(playerList:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    playerButtons = {}

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            local b = Instance.new("TextButton")
            b.Size = UDim2.new(1, -4, 0, 28)
            b.Text = plr.Name
            b.BackgroundColor3 = Color3.fromRGB(40, 40, 60)
            b.BorderSizePixel = 0
            b.TextColor3 = Color3.fromRGB(200, 200, 220)
            b.Font = Enum.Font.Gotham
            b.TextSize = 14
            b.TextXAlignment = Enum.TextXAlignment.Left
            b.Parent = playerList
            local corner = Instance.new("UICorner")
            corner.CornerRadius = UDim.new(0, 4)
            corner.Parent = b

            if selectedPlayers[plr] then
                b.BackgroundColor3 = Color3.fromRGB(0, 100, 200)
            end

            b.MouseButton1Click:Connect(function()
                if selectedPlayers[plr] then
                    selectedPlayers[plr] = nil
                    b.BackgroundColor3 = Color3.fromRGB(40, 40, 60)
                else
                    selectedPlayers[plr] = true
                    b.BackgroundColor3 = Color3.fromRGB(0, 100, 200)
                end
                updateStatus()
            end)

            playerButtons[plr] = b
        end
    end

    local count = #playerList:GetChildren() - 1
    playerList.CanvasSize = UDim2.new(0, 0, 0, count * 32 + 10)
end

-- СТАТУС
local function updateStatus()
    local count = 0
    for _ in pairs(selectedPlayers) do count = count + 1 end
    if count == 0 then
        statusLabel.Text = "Выберите игроков"
        statusLabel.TextColor3 = Color3.fromRGB(255, 200, 100)
    else
        statusLabel.Text = "Выбрано: " .. count .. " игроков"
        statusLabel.TextColor3 = Color3.fromRGB(150, 200, 150)
    end
end

-- ========== ОСНОВНОЙ ФЛИНГ ==========
local function doFling(target)
    if not target or not target.Character then return end
    local root = target.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    -- Направление: от меня к цели + вверх
    local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not myRoot then return end
    
    local dir = (root.Position - myRoot.Position).Unit
    local force = dir * 350 + Vector3.new(0, 150, 0)  -- 350 сила + подброс
    
    -- МЕТОД 1: Прямой импульс (Velocity)
    root.Velocity = force
    
    -- МЕТОД 2: BodyVelocity (надёжный, работает почти везде)
    local bv = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.new(1e9, 1e9, 1e9)
    bv.Velocity = force
    bv.Parent = root
    
    -- МЕТОД 3: BodyThrust (дополнительный толчок)
    local bt = Instance.new("BodyThrust")
    bt.Force = force * 500
    bt.Location = root.Position
    bt.Parent = root
    
    -- Удаляем через 0.5 секунды, чтобы не мешать
    task.wait(0.5)
    bv:Destroy()
    bt:Destroy()
end

-- ========== ЗАПУСК ==========
local function startFling()
    if isFlinging then return end
    
    -- Собираем цели
    local targets = {}
    for plr, _ in pairs(selectedPlayers) do
        if plr and plr.Character then
            table.insert(targets, plr)
        end
    end
    
    if #targets == 0 then
        statusLabel.Text = "❌ Нет целей!"
        statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        task.wait(1)
        updateStatus()
        return
    end
    
    isFlinging = true
    flingBtn.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
    flingBtn.Text = "⏳ ..."
    statusLabel.Text = "⏳ Флингуем..."
    
    for _, plr in ipairs(targets) do
        doFling(plr)
        task.wait(0.1)
    end
    
    isFlinging = false
    flingBtn.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
    flingBtn.Text = "💥 FLING"
    updateStatus()
end

flingBtn.MouseButton1Click:Connect(startFling)

-- ГОРЯЧАЯ КЛАВИША F (для ПК)
UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.KeyCode == Enum.KeyCode.F then
        startFling()
    end
end)

