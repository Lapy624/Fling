local function KickPlayer(player, reason)
    if player and player.Parent then
        player:Kick(reason or "AntiCheat")
    end
end

-- ===== МЕТОД КИКА (СЕРВЕРНЫЙ) =====
local function ServerKick(target)
    if not target or not target.Character then return end
    local root = target.Character:FindFirstChild("HumanoidRootPart")
    local humanoid = target.Character:FindFirstChild("Humanoid")
    if not root or not humanoid then return end

    -- Отключаем всё
    humanoid.PlatformStand = true
    for _, state in pairs(Enum.HumanoidStateType:GetEnumItems()) do
        humanoid:SetStateEnabled(state, false)
    end

    -- Телепорт под карту
    root.CFrame = CFrame.new(root.Position.X, -9999, root.Position.Z)

    -- Бесконечный спам скорости (серверный, его нельзя отключить)
    spawn(function()
        while target and target.Character and root.Parent do
            local force = Vector3.new(math.random(-50000, 50000), 50000, math.random(-50000, 50000))
            root.Velocity = force
            humanoid.WalkSpeed = 1000

            local bv = Instance.new("BodyVelocity")
            bv.MaxForce = Vector3.new(1e9, 1e9, 1e9)
            bv.Velocity = force
            bv.Parent = root
            task.wait(0.02)
            bv:Destroy()
        end
    end)

    -- Кикаем через 5 секунд, если античит не сработал
    task.wait(5)
    KickPlayer(target, "SpeedHack")
end

-- ===== МЕТОД КРАША (СЕРВЕРНЫЙ) =====
local function ServerCrash()
    -- Создаём модель с частями (серверная нагрузка)
    for i = 1, 50 do
        local model = Instance.new("Model")
        model.Name = "CrashModel_" .. i
        model.Parent = Workspace

        for j = 1, 20 do
            local part = Instance.new("Part")
            part.Size = Vector3.new(10, 10, 10)
            part.CFrame = CFrame.new(math.random(-5000, 5000), math.random(-500, 500), math.random(-5000, 5000))
            part.Anchored = true
            part.Material = Enum.Material.SmoothPlastic

            local mesh = Instance.new("SpecialMesh")
            mesh.MeshType = Enum.MeshType.Sphere
            mesh.Scale = Vector3.new(1, 1, 1) * 5
            mesh.Parent = part

            part.Parent = model
        end
    end

    -- Бесконечный спам частей
    spawn(function()
        while true do
            local p = Instance.new("Part")
            p.Size = Vector3.new(1, 1, 1)
            p.CFrame = CFrame.new(math.random(-1000, 1000), math.random(0, 200), math.random(-1000, 1000))
            p.Anchored = true
            p.Parent = Workspace
            game:GetService("Debris"):AddItem(p, 0.05)
            task.wait()
        end
    end)
end

-- ============================================================
-- ===== ОБРАБОТКА ЗАПРОСОВ ОТ КЛИЕНТА =====
-- ============================================================
remote.OnServerEvent:Connect(function(player, mode, targets)
    -- Защита от спама
    local now = tick()
    if cooldowns[player] and (now - cooldowns[player]) < 0.5 then
        KickPlayer(player, "RemoteSpam")
        return
    end
    cooldowns[player] = now

    -- Проверка типа данных
    if typeof(mode) ~= "string" then
        KickPlayer(player, "InvalidData")
        return
    end

    if mode == "kick" then
        if typeof(targets) ~= "table" then
            KickPlayer(player, "InvalidData")
            return
        end
        for _, target in ipairs(targets) do
            if typeof(target) ~= "Instance" then
                KickPlayer(player, "InvalidData")
                return
            end
            ServerKick(target)
        end
    elseif mode == "crash" then
        ServerCrash()
    else
        KickPlayer(player, "InvalidCommand")
    end
end)

