        flingBtn.BackgroundColor3 = Color3.fromRGB(255, 150, 50)
        flingBtn.Text = "⚡ FLING"
    end
end

-- Слайдер
local function setupSlider(slider, indicator, minVal, maxVal, callback)
    local dragging = false

    local function update(posX)
        local rel = math.clamp((posX - slider.AbsolutePosition.X) / slider.AbsoluteSize.X, 0, 1)
        local val = minVal + (maxVal - minVal) * rel
        callback(math.floor(val))
        indicator.Position = UDim2.new(rel, -6, 0, -3)
    end

    slider.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            update(input.Position.X)
        end
    end)

    slider.InputEnded:Connect(function()
        dragging = false
    end)

    slider.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            update(input.Position.X)
        end
    end)

    slider.MouseLeave:Connect(function()
        dragging = false
    end)
end

setupSlider(powerSlider, powerIndicator, 50, 500, function(val)
    flingPower = val
    updatePowerDisplay()
end)

-- Переключение режима
