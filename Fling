-- ============================================================
-- ФУНКЦИЯ: НЕВИДИМОСТЬ (скрывает настоящего игрока, оставляя клона)
-- ============================================================
local function setGhost(state)
    local char = LocalPlayer.Character
    if not char then return end

    if state then
        createGhostClone()

        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Transparency = 1
                part.CanCollide = false
                part.LocalTransparencyModifier = 1
            end
        end
        local nameDisplay = char:FindFirstChild("NameDisplay")
        if nameDisplay then nameDisplay.Enabled = false end

        local root = char:FindFirstChild("HumanoidRootPart")
        if root then
            root.CFrame = CFrame.new(0, -9999, 0)
        end

        local humanoid = char:FindFirstChild("Humanoid")
        if humanoid then
            humanoid.PlatformStand = true
            humanoid.WalkSpeed = 0
        end
    else
        if cloneCharacter then
            cloneCharacter:Destroy()
            cloneCharacter = nil
        end

        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Transparency = 0
                part.CanCollide = true
                part.LocalTransparencyModifier = 0
            end
        end
        local nameDisplay = char:FindFirstChild("NameDisplay")
        if nameDisplay then nameDisplay.Enabled = true end

        local root = char:FindFirstChild("HumanoidRootPart")
        if root then
            root.CFrame = CFrame.new(0, 10, 0)
        end

        local humanoid = char:FindFirstChild("Humanoid")
        if humanoid then
            humanoid.PlatformStand = false
            humanoid.WalkSpeed = 16
        end
    end
end

