-- ========== УНИКАЛЬНЫЙ ФЛИНГ (рывок + вихрь + подброс) ==========
local function uniqueFling()
    local char = LocalPlayer.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    local humanoid = char:FindFirstChild("Humanoid")
    if not root or not humanoid then return end

    local direction = Camera.CFrame.LookVector
    -- Вихревая составляющая (вращение)
    local randomAngle = math.random(0, 360)
    local upDir = Vector3.new(0, 1, 0)
    local rightDir = direction:Cross(upDir).Unit
    local upForce = Vector3.new(0, 1, 0) * (flingPower * 0.7)
    local forwardForce = direction * flingPower * 1.2
    local sideForce = rightDir * math.sin(randomAngle) * flingPower * 0.4

    -- Итоговый импульс
    local finalForce = forwardForce + upForce + sideForce

    -- Применяем силу
    root.Velocity = finalForce

    -- Визуальный эффект: вращение персонажа (для красоты)
    local tween = TweenService:Create(root, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {CFrame = root.CFrame * CFrame.Angles(0, math.rad(360), 0)})
    tween:Play()

    -- Дополнительный импульс через BodyVelocity (для гарантии)
    task.wait(0.05)
    local bv = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.new(1e9, 1e9, 1e9)
    bv.Velocity = finalForce
    bv.Parent = root
    task.wait(0.3)
    bv:Destroy()
end

-- ========== СТАНДАРТНЫЙ ФЛИНГ (как у большинства) ==========
local function classicFling()
    local char = LocalPlayer.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local direction = Camera.CFrame.LookVector + Vector3.new(0, 0.3, 0)
    local force = direction.Unit * flingPower * 1.5

    -- BodyVelocity (основной метод)
    local bv = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.new(1e9, 1e9, 1e9)
    bv.Velocity = force
    bv.Parent = root

    -- Прямой импульс
    root.Velocity = force

    -- Дополнительный BodyThrust
    local bt = Instance.new("BodyThrust")
    bt.Force = force * 500
    bt.Location = root.Position
    bt.Parent = root

    task.wait(0.5)
    bv:Destroy()
    bt:Destroy()
end

-- ========== ОСНОВНАЯ ФУНКЦИЯ FLING ==========
local function doFling()
    if isFlinging then return end
    local char = LocalPlayer.Character
    if not char then return end

    isFlinging = true
    flingBtn.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
    flingBtn.Text = "⏳ FLING..."

    if flingMode == "UNIQUE" then
        uniqueFling()
    else
        classicFling()
    end

    isFlinging = false
    updateModeDisplay() -- возвращаем цвет кнопки
end

-- Нажатие на кнопку
flingBtn.MouseButton1Click:Connect(doFling)

-- Горячая клавиша F
UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.KeyCode == Enum.KeyCode.F then
        doFling()
    end
end)

-- Защита
LocalPlayer.CharacterAdded:Connect(function()
    isFlinging = false
    updateModeDisplay()
end)

