-- ГЛОБАЛЬНЫЕ СОСТОЯНИЯ
-- ============================================================
local ghostActive = false
local godActive = false
local cloneCharacter = nil
local shieldActive = false
local shieldTimer = nil
local healthConnection = nil
local godLoopConnection = nil

-- ============================================================
-- ФУНКЦИЯ: СОЗДАНИЕ КЛОНА-ПРИЗРАКА
-- ============================================================
local function createGhostClone()
    local char = LocalPlayer.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    cloneCharacter = char:Clone()
    cloneCharacter.Name = "GhostClone"
    cloneCharacter.Parent = Workspace

    for _, part in ipairs(cloneCharacter:GetDescendants()) do
        if part:IsA("BasePart") then
            part.Transparency = 0.3
            part.CanCollide = false
            part.Material = Enum.Material.Neon
            part.Color = Color3.fromRGB(0, 200, 255)
        end
    end

    local humanoid = cloneCharacter:FindFirstChild("Humanoid")
    if humanoid then
        humanoid.PlatformStand = true
        humanoid.WalkSpeed = 0
        humanoid.JumpPower = 0
        humanoid.MaxHealth = 9e9
        humanoid.Health = 9e9
        humanoid.BreakJointsOnDeath = false
    end

    local cloneRoot = cloneCharacter:FindFirstChild("HumanoidRootPart")
    if cloneRoot then
        cloneRoot.CFrame = root.CFrame
    end

    local function onCloneHealthChange()
        if not cloneCharacter or not cloneCharacter.Parent then return end
        local h = cloneCharacter:FindFirstChild("Humanoid")
        if h and h.Health < h.MaxHealth then
            h.Health = h.MaxHealth
        end
    end
    if humanoid then
        humanoid:GetPropertyChangedSignal("Health"):Connect(onCloneHealthChange)
    end

    return cloneCharacter
end

-- ============================================================
-- ФУНКЦИЯ: ЩИТ ПРИ СМЕРТИ
-- ============================================================
local function activateShield()
    if shieldActive then return end
    shieldActive = true
    local char = LocalPlayer.Character
    if not char then return end
    local humanoid = char:FindFirstChild("Humanoid")
    if not humanoid then return end

    humanoid.BreakJointsOnDeath = false
    humanoid.MaxHealth = 9e9
    humanoid.Health = 9e9
    humanoid:SetStateEnabled(Enum.HumanoidStateType.Dead, false)

    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            part.Material = Enum.Material.Neon
            part.Color = Color3.fromRGB(0, 255, 255)
        end
    end

    if shieldTimer then shieldTimer:Disconnect() end
    shieldTimer = task.delay(5, function()
        shieldActive = false
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Material = Enum.Material.SmoothPlastic
                part.Color = Color3.fromRGB(255, 255, 255)
            end
        end
        humanoid.BreakJointsOnDeath = true
        humanoid.MaxHealth = 100
        humanoid.Health = 100
        humanoid:SetStateEnabled(Enum.HumanoidStateType.Dead, true)
    end)
end

-- ============================================================
-- ФУНКЦИЯ: ПЕРЕХВАТ УРОНА
-- ============================================================
local function setupGodMode()
    local char = LocalPlayer.Character
    if not char then return end
    local humanoid = char:FindFirstChild("Humanoid")
    if not humanoid then return end

    if healthConnection then healthConnection:Disconnect() end

    healthConnection = humanoid:GetPropertyChangedSignal("Health"):Connect(function()
        if godActive then
            if humanoid.Health < humanoid.MaxHealth then
                humanoid.Health = humanoid.MaxHealth
                if humanoid.Health < humanoid.MaxHealth * 0.5 then
                    activateShield()
                end
            end
        end
    end)

    local mt = getrawmetatable(humanoid)
    if mt then
        local oldIndex = mt.__index
        mt.__index = function(self, key)
            if key == "TakeDamage" then
                return function(self, damage)
                    if godActive then
                        if cloneCharacter then
                            local cloneHumanoid = cloneCharacter:FindFirstChild("Humanoid")
                            if cloneHumanoid then
                                cloneHumanoid.Health = cloneHumanoid.Health - damage
                            end
                        end
                        activateShield()
                        return
                    end
                    return oldIndex(self, key)(self, damage)
                end
            end
            return oldIndex(self, key)
        end
    end
end

