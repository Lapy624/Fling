        createLabel("(Список игроков обновляется автоматически)", Color3.fromRGB(150,150,170))

        createButton("🎯 ТП ЗА СПИНУ", teleportBehind, Color3.fromRGB(200,50,50))
        createButton("↩️ ВЕРНУТЬСЯ", returnBack, Color3.fromRGB(50,200,50))
        createButton("🔄 СБРОСИТЬ ЦЕЛЬ", function()
            if selectedButton then
                selectedButton.BackgroundColor3 = Color3.fromRGB(40,40,60)
                selectedButton = nil
            end
            selectedTarget = nil
            savedPosition = nil
            savedCFrame = nil
            savedCameraCFrame = nil
            print("✅ Цель сброшена")
        end, Color3.fromRGB(60,60,80))

        createToggle("⚔️ Авто-удар", CONFIG.AutoAttack, function(val) CONFIG.AutoAttack = val end)
        createToggle("⏳ Авто-возврат", CONFIG.AutoReturn, function(val) CONFIG.AutoReturn = val end)

    elseif currentTab == "Settings" then
        createSlider("📏 Дистанция ТП", 1, 10, CONFIG.TeleportDistance, function(val)
            CONFIG.TeleportDistance = val
        end)
        createSlider("⏱️ Задержка возврата (сек)", 0.5, 10, CONFIG.ReturnDelay, function(val)
            CONFIG.ReturnDelay = val
        end)
        createToggle("🔄 Плавный телепорт", CONFIG.SmoothTeleport, function(val) CONFIG.SmoothTeleport = val end)
        createToggle("🛡️ Анти-детект", CONFIG.AntiDetect, function(val) CONFIG.AntiDetect = val end)

    elseif currentTab == "Protection" then
        createToggle("⏰ Anti-AFK", CONFIG.AntiAFK, function(val)
            CONFIG.AntiAFK = val
            toggleAntiAFK()
        end)
        createButton("🛡️ Anti-Kick (вкл/выкл)", function()
            toggleAntiKick()
        end, Color3.fromRGB(100,100,200))
        createLabel("💡 Anti-Kick имитирует активность", Color3.fromRGB(150,150,170))
    end

    -- Обновляем список игроков только если вкладка "Teleport"
    if currentTab == "Teleport" then
        updatePlayerList()
    end
end

