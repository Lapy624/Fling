        btn.BackgroundColor3 = (name == currentMode) and Color3.fromRGB(0, 150, 200) or Color3.fromRGB(40, 40, 60)
    end
end

for name, btn in pairs(modeButtons) do
    btn.MouseButton1Click:Connect(function()
        currentMode = name
        updateModeHighlight()
        updateStatus()
        if controlTarget then stopControl() end
    end)
end

-- ===== STATUS =====
local function updateStatus()
    local count = 0
    for _ in pairs(selectedPlayers) do count = count + 1 end
    if count == 0 then
        statusLabel.Text = "Выберите игроков"
        statusLabel.TextColor3 = Color3.fromRGB(255, 200, 100)
    elseif currentMode == "Контроль" and count > 1 then
        statusLabel.Text = "⚠️ Для контроля выберите 1 игрока"
        statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
    else
        statusLabel.Text = "Готов: " .. count .. " целей | Режим: " .. currentMode
        statusLabel.TextColor3 = Color3.fromRGB(150, 200, 150)
    end
end

-- ===== FLING: POWERFUL =====
local function flingPowerful(target)
    if not target or not target.Character then return end
    local root = target.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local localRoot = getLocalRoot()
    if not localRoot then return end

    local dir = (root.Position - localRoot.Position).Unit
    local force = dir * 500 + Vector3.new(0, 200, 0) + Vector3.new(math.random(-100, 100), 0, math.random(-100, 100))

    root.Velocity = force
    local bv = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.new(1e9, 1e9, 1e9)
    bv.Velocity = force
    bv.Parent = root

    local bt = Instance.new("BodyThrust")
    bt.Force = force * 500
    bt.Location = root.Position
    bt.Parent = root

    task.wait(0.5)
    bv:Destroy()
    bt:Destroy()
end

-- ===== FLING: VORTEX =====
local function flingVortex(target)
    if not target or not target.Character then return end
    local root = target.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local localRoot = getLocalRoot()
    if not localRoot then return end

    local center = localRoot.Position
    local dir = (root.Position - center).Unit
    local perp = Vector3.new(-dir.Z, 0, dir.X).Unit

    for i = 1, 10 do
        local angle = i * 0.6
        local radius = 15 + math.sin(i * 0.5) * 5
        local x = center.X + math.cos(angle) * radius
        local z = center.Z + math.sin(angle) * radius
        local y = center.Y + 10 + math.sin(i * 0.8) * 8

        local targetPos = Vector3.new(x, y, z)
        local force = (targetPos - root.Position) * 3 + Vector3.new(0, 15, 0)

        root.Velocity = force
        task.wait(0.05)
    end

    root.Velocity = Vector3.new(0, 250, 0) + Vector3.new(math.random(-80, 80), 0, math.random(-80, 80))
end

-- ===== CONTROL =====
local function startControl(target)
    if controlTarget then stopControl() end
    if not target or not target.Character then return end

    controlTarget = target
    local root = target.Character:FindFirstChild("HumanoidRootPart")
    local humanoid = target.Character:FindFirstChild("Humanoid")
    if not root or not humanoid then return end

    statusLabel.Text = "🎮 Контроль над " .. target.Name
    statusLabel.TextColor3 = Color3.fromRGB(0, 255, 200)

    humanoid.PlatformStand = true
    humanoid:SetStateEnabled(Enum.HumanoidStateType.Jumping, false)

    local bv = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.new(1e9, 1e9, 1e9)
    bv.Velocity = Vector3.new(0, 0, 0)
    bv.Parent = root

    local bg = Instance.new("BodyGyro")
    bg.MaxTorque = Vector3.new(1e9, 1e9, 1e9)
    bg.CFrame = root.CFrame
    bg.Parent = root

    controlConnections = {}

    local moveConn = RunService.RenderStepped:Connect(function()
        if not controlTarget or not controlTarget.Character then
            stopControl()
            return
        end
        local r = controlTarget.Character:FindFirstChild("HumanoidRootPart")
        if not r or not bv then return end

        local move = Vector3.new()
        local cam = workspace.CurrentCamera
        local forward = cam.CFrame.LookVector * Vector3.new(1,0,1)
        local right = cam.CFrame.RightVector

        if UserInputService:IsKeyDown(Enum.KeyCode.W) then move = move + forward end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then move = move - forward end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then move = move - right end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then move = move + right end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then move = move + Vector3.new(0, 1, 0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then move = move - Vector3.new(0, 1, 0) end

        if move.Magnitude > 0 then
            bv.Velocity = move.Unit * 60
        else
            bv.Velocity = Vector3.new(0, 0, 0)
        end

        if bg then
            bg.CFrame = CFrame.new(r.Position, r.Position + Vector3.new(0, 1, 0))
        end
    end)
    table.insert(controlConnections, moveConn)

    local removeConn = controlTarget.CharacterRemoving:Connect(function()
        stopControl()
    end)
    table.insert(controlConnections, removeConn)
end

local function stopControl()
    if controlTarget and controlTarget.Character then
        local humanoid = controlTarget.Character:FindFirstChild("Humanoid")
        if humanoid then
            humanoid.PlatformStand = false
            humanoid:SetStateEnabled(Enum.HumanoidStateType.Jumping, true)
        end
        -- Безопасное удаление BodyVelocity и BodyGyro
        for _, obj in ipairs(controlTarget.Character:GetDescendants()) do
            if obj:IsA("BodyVelocity") or obj:IsA("BodyGyro") then
                obj:Destroy()
            end
        end
    end
    for _, conn in ipairs(controlConnections) do
        conn:Disconnect()
    end
    controlConnections = {}
    controlTarget = nil
    updateStatus()
end

-- ===== START ACTION =====
local function startAction()
    if isRunning then return end

    local targets = {}
    for plr, _ in pairs(selectedPlayers) do
        if plr and plr.Character then
            table.insert(targets, plr)
        end
    end

    if #targets == 0 then
        statusLabel.Text = "❌ Нет целей"
        statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        task.wait(1)
        updateStatus()
        return
    end

    if currentMode == "Контроль" then
        if #targets > 1 then
            statusLabel.Text = "⚠️ Для контроля выберите 1 игрока"
            statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
            task.wait(1.5)
            updateStatus()
            return
        end
        startControl(targets[1])
        return
    end

    isRunning = true
    actionBtn.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
    actionBtn.Text = "⏳ ..."
    statusLabel.Text = "⏳ Выполняется..."

    for _, plr in ipairs(targets) do
        if currentMode == "Мощный" then
            flingPowerful(plr)
        elseif currentMode == "Вихрь" then
            flingVortex(plr)
        end
        task.wait(0.15)
    end

    isRunning = false
    actionBtn.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
    actionBtn.Text = "💥 FLING"
    updateStatus()
end

-- ===== BUTTONS =====
actionBtn.MouseButton1Click:Connect(startAction)

stopBtn.MouseButton1Click:Connect(function()
    if currentMode == "Контроль" then
        stopControl()
    end
    isRunning = false
    actionBtn.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
    actionBtn.Text = "💥 FLING"
    updateStatus()
end)

UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.KeyCode == Enum.KeyCode.F then
        startAction()
    end
end)

