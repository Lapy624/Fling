    local function updatePlayerList()
        for _, child in ipairs(playerList:GetChildren()) do
            if child:IsA("TextButton") then child:Destroy() end
        end

        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= player then
                local b = Instance.new("TextButton")
                b.Size = UDim2.new(1, -4, 0, 28)
                b.Text = plr.Name
                b.BackgroundColor3 = Color3.fromRGB(40, 40, 60)
                b.BorderSizePixel = 0
                b.TextColor3 = Color3.fromRGB(200, 200, 220)
                b.Font = Enum.Font.Gotham
                b.TextSize = 14
                b.TextXAlignment = Enum.TextXAlignment.Left
                b.Parent = playerList
                local corner = Instance.new("UICorner")
                corner.CornerRadius = UDim.new(0, 4)
                corner.Parent = b

                if selectedPlayers[plr] then
                    b.BackgroundColor3 = Color3.fromRGB(0, 100, 200)
                end

                b.MouseButton1Click:Connect(function()
                    if selectedPlayers[plr] then
                        selectedPlayers[plr] = nil
                        b.BackgroundColor3 = Color3.fromRGB(40, 40, 60)
                    else
                        selectedPlayers[plr] = true
                        b.BackgroundColor3 = Color3.fromRGB(0, 100, 200)
                    end
                    updateStatus()
                end)
            end
        end

        local count = #playerList:GetChildren() - 1
        playerList.CanvasSize = UDim2.new(0, 0, 0, count * 32 + 10)
    end

    local function updateStatus()
        local count = 0
        for _ in pairs(selectedPlayers) do count = count + 1 end
        if count == 0 then
            statusLabel.Text = "Выберите игроков"
            statusLabel.TextColor3 = Color3.fromRGB(255, 200, 100)
        else
            statusLabel.Text = "Выбрано: " .. count .. " игроков"
            statusLabel.TextColor3 = Color3.fromRGB(150, 200, 150)
        end
    end

    -- ============================================================
    -- ===== ОТПРАВКА КОМАНД НА СЕРВЕР =====
    -- ============================================================
    local function startAction(mode)
        if isRunning then return end

        local targets = {}
        for plr, _ in pairs(selectedPlayers) do
            if plr and plr.Character then
                table.insert(targets, plr)
            end
        end

        if #targets == 0 and mode ~= "crash" then
            statusLabel.Text = "❌ Нет целей!"
            statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
            task.wait(1)
            updateStatus()
            return
        end

        isRunning = true
        statusLabel.Text = "⏳ Выполняется..."
        statusLabel.TextColor3 = Color3.fromRGB(255, 200, 100)

        -- Отправляем запрос на сервер
        remote:FireServer(mode, targets)

        isRunning = false
        updateStatus()
    end

    kickBtn.MouseButton1Click:Connect(function() startAction("kick") end)
    crashBtn.MouseButton1Click:Connect(function() startAction("crash") end)

    -- Обновление списка при входе/выходе
    Players.PlayerAdded:Connect(updatePlayerList)
    Players.PlayerRemoving:Connect(updatePlayerList)

    updatePlayerList()
    updateStatus()
end

